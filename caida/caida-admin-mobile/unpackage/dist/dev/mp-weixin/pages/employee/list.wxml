<view class="employee-list-container data-v-1620ec36"><view class="search-bar data-v-1620ec36"><input type="text" placeholder="搜索员工姓名/编号" data-event-opts="{{[['confirm',[['handleSearch',['$event']]]],['input',[['__set_model',['','searchKeyword','$event',[]]]]]]}}" value="{{searchKeyword}}" bindconfirm="__e" bindinput="__e" class="data-v-1620ec36"/><button data-event-opts="{{[['tap',[['handleSearch',['$event']]]]]}}" class="search-btn data-v-1620ec36" bindtap="__e">搜索</button></view><view class="filter-bar data-v-1620ec36"><view data-event-opts="{{[['tap',[['filterByStatus',['all']]]]]}}" class="{{['filter-item','data-v-1620ec36',(currentStatus==='all')?'active':'']}}" bindtap="__e"> 全部 </view><view data-event-opts="{{[['tap',[['filterByStatus',[1]]]]]}}" class="{{['filter-item','data-v-1620ec36',(currentStatus===1)?'active':'']}}" bindtap="__e"> 正常 </view><view data-event-opts="{{[['tap',[['filterByStatus',[0]]]]]}}" class="{{['filter-item','data-v-1620ec36',(currentStatus===0)?'active':'']}}" bindtap="__e"> 已禁用 </view></view><scroll-view class="employee-scroll data-v-1620ec36" scroll-y="{{true}}" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" data-event-opts="{{[['scrolltolower',[['loadMore',['$event']]]],['refresherrefresh',[['onRefresh',['$event']]]]]}}" bindscrolltolower="__e" bindrefresherrefresh="__e"><view class="employee-list data-v-1620ec36"><block wx:for="{{employeeList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="employee-item data-v-1620ec36"><view class="employee-header data-v-1620ec36"><view class="employee-info data-v-1620ec36"><view class="name-row data-v-1620ec36"><text class="employee-name data-v-1620ec36">{{item.name}}</text><view class="{{['employee-status','data-v-1620ec36',(item.status===0)?'disabled':'']}}">{{''+(item.status===1?'正常':'已禁用')+''}}</view></view><text class="employee-no data-v-1620ec36">{{"员工编号: "+item.employeeNo}}</text></view></view><view class="employee-details data-v-1620ec36"><view