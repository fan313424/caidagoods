<view class="user-list-container data-v-1fd50f39"><view class="search-bar data-v-1fd50f39"><input type="text" placeholder="搜索用户名/手机号" data-event-opts="{{[['confirm',[['handleSearch',['$event']]]],['input',[['__set_model',['','searchKeyword','$event',[]]]]]]}}" value="{{searchKeyword}}" bindconfirm="__e" bindinput="__e" class="data-v-1fd50f39"/><button data-event-opts="{{[['tap',[['handleSearch',['$event']]]]]}}" class="search-btn data-v-1fd50f39" bindtap="__e">搜索</button></view><view class="filter-bar data-v-1fd50f39"><view data-event-opts="{{[['tap',[['filterByStatus',['all']]]]]}}" class="{{['filter-item','data-v-1fd50f39',(currentStatus==='all')?'active':'']}}" bindtap="__e"> 全部 </view><view data-event-opts="{{[['tap',[['filterByStatus',[1]]]]]}}" class="{{['filter-item','data-v-1fd50f39',(currentStatus===1)?'active':'']}}" bindtap="__e"> 正常 </view><view data-event-opts="{{[['tap',[['filterByStatus',[0]]]]]}}" class="{{['filter-item','data-v-1fd50f39',(currentStatus===0)?'active':'']}}" bindtap="__e"> 已禁用 </view></view><scroll-view class="user-scroll data-v-1fd50f39" scroll-y="{{true}}" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" data-event-opts="{{[['scrolltolower',[['loadMore',['$event']]]],['refresherrefresh',[['onRefresh',['$event']]]]]}}" bindscrolltolower="__e" bindrefresherrefresh="__e"><view class="user-list data-v-1fd50f39"><block wx:for="{{userList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="user-item data-v-1fd50f39"><image class="user-avatar data-v-1fd50f39" src="{{item.avatar||'/static/default-avatar.png'}}" mode="aspectFill"></image><view class="user-info data-v-1fd50f39"><view class="user-name-row data-v-1fd50f39"><text class="user-name data-v-1fd50f39">{{item.nickname||item.username}}</text><view class="{{['user-status','data-v-1fd50f39',(item.status===0)?'disabled':'']}}">{{''+(item.status===1?'正常':'已禁用')+''}}</view></view><text class="user-phone data-v-1fd50f39">{{item.phone||'未绑定手机'}}</text><text