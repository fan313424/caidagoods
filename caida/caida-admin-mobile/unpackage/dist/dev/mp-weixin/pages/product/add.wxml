<view class="add-product-container data-v-1614eb18"><view class="form-section data-v-1614eb18"><view class="form-item data-v-1614eb18"><text class="label data-v-1614eb18">商品名称</text><input type="text" placeholder="请输入商品名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['form']]]]]}}" value="{{form.name}}" bindinput="__e" class="data-v-1614eb18"/></view><view class="form-item data-v-1614eb18"><text class="label data-v-1614eb18">商品分类</text><picker mode="selector" range="{{categories}}" data-event-opts="{{[['change',[['onCategoryChange',['$event']]]]]}}" bindchange="__e" class="data-v-1614eb18"><view class="picker data-v-1614eb18">{{''+(form.category||'请选择分类')+''}}<text class="arrow data-v-1614eb18">></text></view></picker></view><view class="form-item data-v-1614eb18"><text class="label data-v-1614eb18">商品价格</text><input type="digit" placeholder="请输入价格" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',[]],['form']]]]]}}" value="{{form.price}}" bindinput="__e" class="data-v-1614eb18"/></view><view class="form-item data-v-1614eb18"><text class="label data-v-1614eb18">库存数量</text><input type="number" placeholder="请输入库存" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','stock','$event',[]],['form']]]]]}}" value="{{form.stock}}" bindinput="__e" class="data-v-1614eb18"/></view><view class="form-item data-v-1614eb18"><text class="label data-v-1614eb18">商品图片</text><view class="image-upload data-v-1614eb18"><block wx:if="{{form.imageUrl}}"><view class="image-item data-v-1614eb18"><image src="{{form.imageUrl}}" mode="aspectFill" class="data-v-1614eb18"></image><view data-event-opts="{{[['tap',[['deleteImage',['$event']]]]]}}" class="delete-btn data-v-1614eb18" bindtap="__e">×</view></view></block><block wx:else><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="upload-btn data-v-1614eb18" bindtap="__e"><text class="plus data-v-1614eb18">+</text><text class="text data-v-1614eb18">上传图片</text></view></block></view></view><view class="form-item textarea-item data-v-1614eb18"><text class="label data-v-1614eb18">商品描述</text><textarea placeholder="请输入商品描述" placeholder-class="placeholder" maxlength="500" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['form']]]]]}}" value="{{form.description}}" bindinput="__e" class="data-v-1614eb18"></textarea></view></view><view class="form-actions data-v-1614eb18"><button data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" class="cancel-btn data-v-1614eb18" bindtap="__e">取消</button><button class="submit-btn data-v-1614eb18" loading="{{loading}}" data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" bindtap="__e">{{''+(loading?'提交中...':'提交')+''}}</button></view></view>