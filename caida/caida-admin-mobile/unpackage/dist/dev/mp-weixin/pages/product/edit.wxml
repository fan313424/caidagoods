<view class="edit-product-container data-v-584f1f23"><view class="form-section data-v-584f1f23"><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">商品名称</text><input type="text" placeholder="请输入商品名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['form']]]]]}}" value="{{form.name}}" bindinput="__e" class="data-v-584f1f23"/></view><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">商品分类</text><picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" data-event-opts="{{[['change',[['onCategoryChange',['$event']]]]]}}" bindchange="__e" class="data-v-584f1f23"><view class="picker data-v-584f1f23">{{''+(form.category||'请选择分类')+''}}<text class="arrow data-v-584f1f23">></text></view></picker></view><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">商品价格</text><input type="digit" placeholder="请输入价格" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',[]],['form']]]]]}}" value="{{form.price}}" bindinput="__e" class="data-v-584f1f23"/></view><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">库存数量</text><input type="number" placeholder="请输入库存" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','stock','$event',[]],['form']]]]]}}" value="{{form.stock}}" bindinput="__e" class="data-v-584f1f23"/></view><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">商品状态</text><view class="status-switch data-v-584f1f23"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['status-item','data-v-584f1f23',(form.status===1)?'active':'']}}" bindtap="__e"> 上架 </view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['status-item','data-v-584f1f23',(form.status===0)?'active':'']}}" bindtap="__e"> 下架 </view></view></view><view class="form-item data-v-584f1f23"><text class="label data-v-584f1f23">商品图片</text><view class="image-upload data-v-584f1f23"><block wx:if="{{form.imageUrl}}"><view class="image-item data-v-584f1f23"><image src="{{form.imageUrl}}" mode="aspectFill" class="data-v-584f1f23"></image><view data-event-opts="{{[['tap',[['deleteImage',['$event']]]]]}}" class="delete-btn data-v-584f1f23" bindtap="__e">×</view></view></block><block wx:else><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="upload-btn data-v-584f1f23" bindtap="__e"><text class="plus data-v-584f1f23">+</text><text class="text data-v-584f1f23">上传图片</text></view></block></view></view><view class="form-item textarea-item data-v-584f1f23"><text class="label data-v-584f1f23">商品描述</text><textarea placeholder="请输入商品描述" placeholder-class="placeholder" maxlength="500" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['form']]]]]}}" value="{{form.description}}" bindinput="__e" class="data-v-584f1f23"></textarea></view></view><view class="form-actions data-v-584f1f23"><button data-event-opts="{{[['tap',[['deleteProduct',['$event']]]]]}}" class="delete-btn data-v-584f1f23" bindtap="__e">删除</button><button class="submit-btn data-v-584f1f23" loading="{{loading}}" data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" bindtap="__e">{{''+(loading?'保存中...':'保存')+''}}</button></view></view>