<view class="index-container data-v-57280228"><view class="header data-v-57280228"><view class="welcome data-v-57280228"><text class="hello data-v-57280228">你好，</text><text class="name data-v-57280228">{{adminInfo.realName||adminInfo.username}}</text></view><view class="role data-v-57280228">{{adminInfo.role===1?'超级管理员':'普通管理员'}}</view></view><view class="stats-container data-v-57280228"><view class="stats-title data-v-57280228">今日数据</view><view class="stats-grid data-v-57280228"><view class="stats-item data-v-57280228"><text class="stats-value data-v-57280228">{{stats.userCount}}</text><text class="stats-label data-v-57280228">用户总数</text></view><view class="stats-item data-v-57280228"><text class="stats-value data-v-57280228">{{stats.productCount}}</text><text class="stats-label data-v-57280228">商品总数</text></view><view class="stats-item data-v-57280228"><text class="stats-value data-v-57280228">{{stats.orderCount}}</text><text class="stats-label data-v-57280228">订单总数</text></view><view class="stats-item data-v-57280228"><text class="stats-value data-v-57280228">{{stats.employeeCount}}</text><text class="stats-label data-v-57280228">员工总数</text></view></view></view><view class="quick-actions data-v-57280228"><view class="section-title data-v-57280228">快捷功能</view><view class="actions-grid data-v-57280228"><view data-event-opts="{{[['tap',[['navigateTo',['/pages/product/add']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);">📦</view><text class="action-text data-v-57280228">添加商品</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/product/list']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);">📋</view><text class="action-text data-v-57280228">商品列表</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/user/list']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);">👥</view><text class="action-text data-v-57280228">用户管理</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/employee/list']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #9C27B0 0%, #BA68C8 100%);">👔</view><text class="action-text data-v-57280228">员工管理</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/order/list']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);">🛒</view><text class="action-text data-v-57280228">订单管理</text></view><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="action-item data-v-57280228" bindtap="__e"><view class="action-icon data-v-57280228" style="background:linear-gradient(135deg, #607D8B 0%, #78909C 100%);">🚪</view><text class="action-text data-v-57280228">退出登录</text></view></view></view><view class="recent-activity data-v-57280228"><view class="section-title data-v-57280228">最近动态</view><view class="activity-list data-v-57280228"><block wx:for="{{activities}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="activity-item data-v-57280228"><view class="activity-dot data-v-57280228"></view><view class="activity-content data-v-57280228"><text class="activity-text data-v-57280228">{{item.text}}</text><text class="activity-time data-v-57280228">{{item.time}}</text></view></view></block></view></view></view>