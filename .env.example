# ============================================
# 财大优选 - 环境变量配置模板
# ============================================
# 使用方式：
#   1. 复制此文件为 .env（注意：.env 已在 .gitignore 中，不会被提交）
#   2. 填入你的实际密钥和密码
#   3. IDEA 用户：安装 EnvFile 插件，或通过 Run Configuration 设置
#   4. 命令行启动：参考下方说明
# ============================================

# ---------- 数据库配置 ----------
DB_USERNAME=root
DB_PASSWORD=your_password_here

# ---------- 服务器配置 ----------
SERVER_PORT=8080

# ---------- DeepSeek AI API Key（必填）----------
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API URL（可选，默认值即可，一般不需要设置）
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ---------- 管理员默认密码（仅首次初始化时使用）----------
ADMIN_DEFAULT_PASSWORD=admin123
